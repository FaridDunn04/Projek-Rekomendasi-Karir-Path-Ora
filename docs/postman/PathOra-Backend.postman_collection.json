    {
      "name": "🤖 Analyses",
      "description": "Trigger analisis CV, ambil hasil analisis. analysisId tersimpan otomatis setelah trigger berhasil.",
      "item": [
        {
          "name": "Trigger Analysis",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const cvId = pm.environment.get('cvId');",
                  "if (!cvId) {",
                  "  console.warn('⚠️  cvId belum tersimpan. Jalankan Upload CV — Text terlebih dahulu.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response shape valid', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error).to.be.null;",
                  "  pm.expect(body.data).to.be.an('object');",
                  "});",
                  "pm.test('data berisi field kontrak AI', () => {",
                  "  const { data } = pm.response.json();",
                  "  pm.expect(data).to.have.property('analysisId');",
                  "  pm.expect(data).to.have.property('predicted_category').that.is.a('string');",
                  "  pm.expect(data).to.have.property('confidence').that.is.a('number');",
                  "  pm.expect(data).to.have.property('top_5_predictions').that.is.an('array');",
                  "  pm.expect(data).to.have.property('extracted_skills').that.is.an('array');",
                  "  pm.expect(data).to.have.property('career_recommendations').that.is.an('array');",
                  "});",
                  "pm.test('confidence antara 0 dan 1', () => {",
                  "  const { confidence } = pm.response.json().data;",
                  "  pm.expect(confidence).to.be.at.least(0).and.at.most(1);",
                  "});",
                  "pm.test('top_5_predictions — semua confidence > 0.05 (FR-016)', () => {",
                  "  const { top_5_predictions } = pm.response.json().data;",
                  "  top_5_predictions.forEach(p => {",
                  "    pm.expect(p.confidence).to.be.above(0.05);",
                  "  });",
                  "});",
                  "pm.test('career_recommendations — semua match_score > 0.3 (FR-020)', () => {",
                  "  const { career_recommendations } = pm.response.json().data;",
                  "  career_recommendations.forEach(r => {",
                  "    pm.expect(r.match_score).to.be.above(0.3);",
                  "  });",
                  "});",
                  "// ✅ Simpan analysisId",
                  "const { data } = pm.response.json();",
                  "if (data && data.analysisId) {",
                  "  pm.environment.set('analysisId', data.analysisId);",
