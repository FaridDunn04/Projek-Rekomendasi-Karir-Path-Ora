    {
      "name": "📄 CVs",
      "description": "Upload, list, get, delete CV. cvId tersimpan otomatis setelah upload berhasil.",
      "item": [
        {
          "name": "Upload CV — Text",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Pastikan raw_text minimal 100 karakter (VAL-003)",
                  "const sampleText = 'Saya adalah seorang software engineer dengan pengalaman 3 tahun di bidang pengembangan web menggunakan Node.js, TypeScript, React, dan PostgreSQL. Saya memiliki keahlian dalam membangun RESTful API, desain database relasional, serta implementasi CI/CD pipeline. Saya juga berpengalaman dalam penggunaan Docker dan Kubernetes untuk deployment aplikasi skala besar.';",
                  "pm.environment.set('sampleCvText', sampleText);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response shape valid', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error).to.be.null;",
                  "  pm.expect(body.data).to.have.property('id');",
                  "});",
                  "pm.test('source_type adalah text', () => {",
                  "  pm.expect(pm.response.json().data.source_type).to.equal('text');",
                  "});",
                  "// ✅ Simpan cvId untuk request berikutnya",
                  "const { data } = pm.response.json();",
                  "if (data && data.id) {",
                  "  pm.environment.set('cvId', data.id);",
                  "  console.log('✅ cvId tersimpan:', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_type\": \"text\",\n  \"raw_text\": \"{{sampleCvText}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/cvs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "cvs"]
            }
          }
        },
        {
          "name": "Upload CV — Text Terlalu Pendek (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 422 — raw_text < 100 karakter', () => pm.response.to.have.status(422));",
                  "pm.test('error.details ada', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error).to.not.be.null;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_type\": \"text\",\n  \"raw_text\": \"Terlalu pendek\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/cvs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "cvs"]
            }
          }
        },
