{
  "info": {
    "_postman_id": "pathora-backend-collection-v1",
    "name": "Path`Ora Backend API",
    "description": "Koleksi endpoint lengkap Path`Ora Backend API (F1–F7).\n\nBase URL: {{baseUrl}}/api/v1\n\nAlur pengujian yang disarankan:\n1. Auth → Register\n2. Auth → Login (token tersimpan otomatis)\n3. CVs → Upload Text / Upload File\n4. CVs → Trigger Analysis\n5. Analyses → Get Analysis by ID\n6. Dashboard → Get My Dashboard\n7. Users → Get Profile / Update Profile",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level pre-request: pastikan baseUrl tidak trailing slash",
          "const base = pm.collectionVariables.get('baseUrl') || pm.environment.get('baseUrl');",
          "if (base && base.endsWith('/')) {",
          "  pm.collectionVariables.set('baseUrl', base.slice(0, -1));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "description": "Registrasi, login. Token JWT disimpan otomatis ke environment variable `authToken` setelah login berhasil.",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate email unik agar tidak conflict saat dijalankan berulang",
                  "const ts = Date.now();",
                  "pm.environment.set('registerEmail', `testuser_${ts}@pathora.dev`);",
                  "pm.environment.set('registerPassword', 'Password123!');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response shape: data/error/meta', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.all.keys('data', 'error', 'meta');",
                  "  pm.expect(body.error).to.be.null;",
                  "});",
                  "pm.test('data berisi id, email, full_name, created_at', () => {",
                  "  const { data } = pm.response.json();",
                  "  pm.expect(data).to.have.all.keys('id', 'email', 'full_name', 'created_at');",
                  "});",
                  "pm.test('password_hash TIDAK ada di response (SEC-001)', () => {",
                  "  const { data } = pm.response.json();",
                  "  pm.expect(data).to.not.have.property('password_hash');",
                  "  pm.expect(data).to.not.have.property('password');",
                  "});",
                  "// Simpan userId untuk dipakai test lain",
                  "const { data } = pm.response.json();",
                  "if (data && data.id) pm.environment.set('registeredUserId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Rani Pratiwi\",\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Register — Validasi Gagal (email invalid)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 422 Unprocessable Entity', () => pm.response.to.have.status(422));",
                  "pm.test('error.message ada', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error).to.not.be.null;",
                  "  pm.expect(body.error.message).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"A\",\n  \"email\": \"bukan-email\",\n  \"password\": \"short\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },

        {
          "name": "Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Gunakan credential dari env; fallback ke default test account",
                  "if (!pm.environment.get('loginEmail')) {",
                  "  pm.environment.set('loginEmail', pm.environment.get('registerEmail') || 'test@pathora.dev');",
                  "}",
                  "if (!pm.environment.get('loginPassword')) {",
                  "  pm.environment.set('loginPassword', pm.environment.get('registerPassword') || 'Password123!');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response shape: data/error/meta', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.all.keys('data', 'error', 'meta');",
                  "  pm.expect(body.error).to.be.null;",
                  "});",
                  "pm.test('data berisi token dan user', () => {",
                  "  const { data } = pm.response.json();",
                  "  pm.expect(data).to.have.property('token').that.is.a('string');",
                  "  pm.expect(data).to.have.property('user');",
                  "  pm.expect(data.user).to.have.all.keys('id', 'email', 'full_name', 'created_at');",
                  "});",
                  "pm.test('token adalah JWT (3 segmen base64)', () => {",
                  "  const { data } = pm.response.json();",
                  "  pm.expect(data.token.split('.').length).to.equal(3);",
                  "});",
                  "pm.test('password_hash TIDAK ada di user (SEC-001)', () => {",
                  "  const { data } = pm.response.json();",
                  "  pm.expect(data.user).to.not.have.property('password_hash');",
                  "});",
                  "// ✅ Simpan token & userId ke environment untuk request berikutnya",
                  "const { data } = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.environment.set('authToken', data.token);",
                  "  pm.environment.set('currentUserId', data.user.id);",
                  "  console.log('✅ authToken tersimpan:', data.token.substring(0, 30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Login — Kredensial Salah",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401 Unauthorized', () => pm.response.to.have.status(401));",
                  "pm.test('Pesan error generik (tidak menyebut field spesifik)', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error.message).to.equal('Email atau password salah');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tidakada@pathora.dev\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },

