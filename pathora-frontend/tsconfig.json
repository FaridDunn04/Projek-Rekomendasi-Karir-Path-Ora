{
	"compilerOptions": {
		"target": "ES2020",
		"module": "nodenext",
		"lib": ["DOM", "ES2020"],
		"jsx": "react-jsx",
		"strict": true,
		"moduleResolution": "nodenext",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"types": ["vite/client"],
		"isolatedModules": true,
		"noEmit": true
	},
	"include": ["src", "src/vite-env.d.ts"],
	"exclude": ["node_modules", "dist"]
}
