# ============================================================================
# Path`Ora Backend - Environment Variables (Example)
# Copy this file to .env, then adjust the values for your environment.
# Do not commit the real .env file to version control.
# ============================================================================

# Server
PORT=8000
NODE_ENV=development

# Database
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://developer:password@localhost:5432/pathora_db

# JWT
# Minimum 32 characters. Generate a strong secret with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_random_secret_of_at_least_32_characters
JWT_EXPIRES_IN=1h

# AI Gateway
# Set true for development without a real AI service.
USE_MOCK_AI=true

# Required when USE_MOCK_AI=false.
AI_BASE_URL=http://localhost:8001
AI_TIMEOUT_MS=30000
AI_API_KEY=change_this_if_your_ai_service_requires_an_api_key

# CORS
# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Upload
MAX_FILE_SIZE_MB=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_MAX=10
STRICT_RATE_LIMIT_MAX=10

# Logging
# Level: fatal | error | warn | info | debug | trace
LOG_LEVEL=debug
