# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (pilih salah satu: DATABASE_URL atau konfigurasi individual) ──────
# Opsi 1 – connection string lengkap (prioritas utama)
DATABASE_URL=postgresql://user:password@localhost:5432/pathora_db

# Opsi 2 – konfigurasi individual (digunakan jika DATABASE_URL tidak di-set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pathora_db
DB_USER=postgres
DB_PASSWORD=your_password

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ── AI Gateway ────────────────────────────────────────────────────────────────
AI_GATEWAY_URL=http://localhost:8000
AI_GATEWAY_API_KEY=your_ai_gateway_api_key
